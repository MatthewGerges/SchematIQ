        {"ref": "C8", "pin": "1", "sheet": "USB_To_I2C"},
        {"ref": "U3", "pin": "6", "pin_name": "VDDIO", "sheet": "BME280_Sensor"},
        {"ref": "U3", "pin": "8", "pin_name": "VDD", "sheet": "BME280_Sensor"},
        {"ref": "C9", "pin": "1", "sheet": "BME280_Sensor"},
        {"ref": "C10", "pin": "1", "sheet": "BME280_Sensor"}
      ]
    },
    {
