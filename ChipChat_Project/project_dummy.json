        {"ref": "J1", "pin": "S1", "pin_name": "SHIELD", "sheet": "USBC"},
        {"ref": "U1", "pin": "1", "pin_name": "GND", "sheet": "Buck_Converter"},
        {"ref": "U2", "pin": "14", "pin_name": "VSS", "sheet": "USB_To_I2C"},
        {"ref": "U3", "pin": "1", "pin_name": "GND", "sheet": "BME280_Sensor"},
